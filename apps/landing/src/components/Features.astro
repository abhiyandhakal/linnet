---
const features = [
  {
    title: "Quick Capture",
    description: "Speak or type naturally. Linnet instantly extracts tasks, events, and notes with full context.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>`
  },
  {
    title: "Contextual Briefing",
    description: "Start your day with an AI-generated briefing that connects your tasks, events, and notes intelligently.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`
  },
  {
    title: "Smart Rescheduling",
    description: "Linnet proactively suggests new times for overdue tasks based on your calendar availability.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/><path d="M21.5 21.5l-3.35-3.35"/></svg>`
  }
];
---
<section class="py-20 px-4 bg-white/30 backdrop-blur-sm border-y border-[var(--border)]">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-3 gap-8">
      {features.map(feature => (
        <div class="p-8 border border-[var(--border)] rounded-xl bg-[var(--paper)] hover:shadow-md transition-shadow">
          <div class="w-12 h-12 bg-[#E63946]/10 text-[var(--red-pen)] rounded-full flex items-center justify-center mb-6" set:html={feature.icon} />
          <h3 class="text-2xl mb-3 font-serif">{feature.title}</h3>
          <p class="text-[var(--muted-ink)] leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
